{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".agent-hooks/omc-session-start.sh codex",
            "name": "omc-session-start",
            "description": "OMC 세션 컨텍스트 + BM25 교훈 자동 주입"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".agent-hooks/omc-pipeline-check.sh",
            "name": "omc-pipeline-check",
            "description": "파이프라인 가드 — CONTRACT 미등록 파일 수정 차단 (exit 2)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".agent-hooks/omc-prompt-inject.sh",
            "name": "omc-prompt-inject",
            "description": "사용자 메시지 기반 BM25 교훈 자동 주입",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".agent-hooks/omc-hub-push.sh",
            "name": "omc-hub-push",
            "description": "omc_* 파일 수정 후 hub 자동 동기화"
          }
        ]
      }
    ]
  }
}
